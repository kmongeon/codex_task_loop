{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Task Series Manifest",
  "description": "Manifest execution authorizes only the documented runner-owned Git lifecycle for this manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": ["series_id", "series_branch", "workspace_root", "packets"],
  "properties": {
    "series_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "series_branch": {
      "type": "string",
      "minLength": 1,
      "description": "Branch used by the runner for this series. Prefer codex/<slug> unless the manifest intentionally assigns a different branch convention.",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "workspace_root": {"type": "string", "minLength": 1},
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packet_id", "task", "depends_on"],
        "properties": {
          "packet_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "task": {"type": "string", "minLength": 1},
          "depends_on": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
                }
              }
            ]
          }
        }
      }
    }
  }
}
